      "protocol": "GL-ACK"
    },
    "receipt": {
      "env": "RECEIPT_DB_ID",
      "purpose": "执行回执数据库",
      "direction": "github-to-notion",
      "protocol": "GL-ACK"
    },
    "syslog": {
      "env": "NOTION_SYSLOG_DB_ID",
      "purpose": "GitHub SYSLOG 收件箱",
      "direction": "github-to-notion",
      "protocol": "SYSLOG"
    },
    "wake_request": {
      "env": "WAKE_REQUEST_DB_ID",
      "purpose": "人格体唤醒请求",
      "direction": "notion-to-github",
      "protocol": "WAKE"
    },
    "broadcast": {
      "env": "BROADCAST_DB_ID",
      "purpose": "广播数据库",
      "direction": "notion-to-github",
      "protocol": "BROADCAST"
    }
