    },
    "L3": {
      "name": "架构干预",
      "types": ["balance_long_drift", "ontology_conflict", "cross_system_architecture"],
      "handler": "manual",
      "notify": { "target": "TCS-0002∞-冰朔", "channel": "github_issue" }
    }
  },
