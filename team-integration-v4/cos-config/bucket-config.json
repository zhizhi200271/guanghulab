{
  "system": "光湖团队接入系统 v4.0",
  "cos_config": {
    "own_bucket": {
      "name": "TODO: 你的COS桶名称",
      "region": "TODO: ap-guangzhou 或 ap-singapore",
      "secret_id_env": "ZY_COS_SECRET_ID",
      "secret_key_env": "ZY_COS_SECRET_KEY"
    },
    "zhuyuan_bucket": {
      "name_env": "ZY_ZHUYUAN_COS_BUCKET",
      "purpose": "向铸渊发送汇报/接收指令",
      "write_path": "team-reports/{persona_id}/",
      "read_path": "team-commands/{persona_id}/"
    },
    "industry_bucket": {
      "name": "TODO: 行业总桶名称（如果属于某个行业）",
      "purpose": "接收行业主控的指令",
      "read_path": "commands/{persona_id}/",
      "write_path": "reports/{persona_id}/"
    }
  },
  "paths": {
    "heartbeat": "heartbeat/{persona_id}/latest.json",
    "daily_report": "reports/{persona_id}/{date}.json",
    "growth_snapshot": "growth/{persona_id}/{date}.json",
    "alert": "alerts/{persona_id}/{timestamp}.json"
  }
}
